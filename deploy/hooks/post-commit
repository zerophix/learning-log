#!/bin/bash
# post-commit — 自动记录 git commit 到 Learning Log（L2 Phase 格式）
# 任何 AI 代理提交后自动触发。后端离线时静默跳过。

set +e
BACKEND_URL="http://localhost:8002/api/stats"
curl -sf "$BACKEND_URL" >/dev/null 2>&1 || exit 0

REPO_DIR="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -z "$REPO_DIR" ] && exit 0

# 全部在 Python 中完成，绕开 bash 编码陷阱
"$HOME/.local/bin/learnlog" _commit-hook "$REPO_DIR" 2>/dev/null || true
