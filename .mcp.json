{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/mingxilv/.learning-log",
        "/Users/mingxilv/learn",
        "/Users/mingxilv/Library/Mobile Documents/com~apple~CloudDocs/Obsidian/vibe-coding"
      ],
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "bash",
        "/Users/mingxilv/.local/bin/gh-mcp-wrapper.sh"
      ],
      "enabled": true
    },
    "learning-log": {
      "type": "sse",
      "url": "http://localhost:8010/sse",
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": [
        "playwright-mcp",
        "--headless"
      ],
      "enabled": true,
      "environment": {
        "PLAYWRIGHT_BROWSERS_PATH": "~/.cache/ms-playwright"
      }
    },
    "sqlite": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-server-sqlite-npx",
        "/Users/mingxilv/PycharmProjects/learning-log/data/learning-log.db"
      ],
      "enabled": true
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp"
      ],
      "enabled": true
    }
  }
}